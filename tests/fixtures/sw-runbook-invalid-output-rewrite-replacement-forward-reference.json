{
  "entries": [
    {
      "type": "Command",
      "commands": [
        "printf 'audio file> target/audio/audio_20260312_142351.mp3\\n'"
      ],
      "output": {
        "rewrite": [
          {
            "type": "replace",
            "pattern": "audio_\\d{8}_\\d{6}\\.mp3",
            "replacement": "@{audio_name}"
          }
        ]
      }
    },
    {
      "type": "Command",
      "commands": [
        "printf 'NAME=demo.mp3\\n'"
      ],
      "capture": [
        {
          "name": "audio_name",
          "source": "stdout",
          "stage": "raw",
          "pattern": "NAME=(.+)"
        }
      ]
    }
  ]
}
