{
  "entries": [
    {
      "type": "Command",
      "commands": [
        "sleep 30 &",
        "PID=$!",
        "printf '%s\\n' \"$PID\" > auto-cleanup-success.pid",
        "echo 'started background process'"
      ]
    },
    {
      "type": "Command",
      "commands": [
        "PID=$(cat auto-cleanup-success.pid)",
        "STATE=$(ps -o stat= -p \"$PID\" 2>/dev/null | tr -d '[:space:]')",
        "if [ -n \"$STATE\" ] && [ \"${STATE#Z}\" = \"$STATE\" ]; then printf 'alive\\n' > auto-cleanup-success-state.txt; else printf 'dead\\n' > auto-cleanup-success-state.txt; fi"
      ]
    }
  ]
}
