{
  "entries": [
    {
      "type": "Command",
      "commands": [
        "printf '%s\\n' '@{generated_path}'"
      ]
    },
    {
      "type": "Command",
      "commands": [
        "printf '/tmp/value.txt\\n'"
      ],
      "capture": [
        {
          "name": "generated_path",
          "source": "stdout",
          "stage": "raw",
          "pattern": "(.+)"
        }
      ]
    }
  ]
}
